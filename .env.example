# ============================================================================
#  ENVIRONMENT VARIABLES
#  Copy this file to ".env" and paste YOUR OWN values.
#  NEVER commit your real .env file. NEVER put secret keys in VITE_* variables
#  (anything prefixed with VITE_ is exposed to the browser).
# ============================================================================

# --- Supabase (YOUR project) ---------------------------------------------
# Find these in: Supabase Dashboard -> Project Settings -> Data API / API Keys
# The anon (publishable) key is SAFE for the frontend. RLS protects your data.
VITE_SUPABASE_URL="PASTE_MY_SUPABASE_URL_HERE"
VITE_SUPABASE_ANON_KEY="PASTE_MY_SUPABASE_ANON_KEY_HERE"

# The SERVICE ROLE key bypasses Row Level Security. It must NEVER be used in
# frontend code and is NOT required for this app. Only add it server-side if
# you later build trusted server functions that need it.
# SUPABASE_SERVICE_ROLE_KEY="NEVER_USE_IN_FRONTEND_ONLY_SERVER_SIDE_IF_REQUIRED"

# --- Analytics / Tracking (optional, paste later) ------------------------
VITE_GA_MEASUREMENT_ID="PASTE_MY_GA4_ID_HERE"           # e.g. G-XXXXXXXXXX
VITE_CLARITY_PROJECT_ID="PASTE_MY_CLARITY_ID_HERE"      # Microsoft Clarity
VITE_GSC_VERIFICATION="PASTE_GOOGLE_SEARCH_CONSOLE_META_TOKEN_HERE"

# --- Google AdSense (optional, paste later) ------------------------------
VITE_ADSENSE_PUBLISHER_ID="ca-pub-XXXXXXXXXXXXXXXX"     # your AdSense publisher ID

# --- Site config ----------------------------------------------------------
VITE_SITE_URL="https://factonia.in"                     # used for canonical/sitemap
VITE_SITE_NAME="Factonia"
